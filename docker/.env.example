# RabbitMQ credentials (dev defaults, synthetic only).
# NOTE: docker/rabbitmq/definitions.json preloads the user "broker" with a
# hash of the password "broker" (RabbitMQ skips env-based default-user
# creation when a definitions file is loaded). If you change the values
# below, regenerate the password_hash in definitions.json to match.
RABBITMQ_USER=broker
RABBITMQ_PASS=broker
